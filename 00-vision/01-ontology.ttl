@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix ef: <http://eposforge.org/ontology/> .

ef:Ontology rdf:type owl:Ontology ;
    rdfs:label "EposForge Dark Factory Ontology" ;
    rdfs:comment "Formal vocabulary, taxonomy, and relationships for the EposForge dark factory pattern. Source of truth: this file. To add a term, declare it here; use it elsewhere by reference. See the maintain-ontology skill for editorial workflow." .

### Classes

ef:DarkFactory rdf:type owl:Class ;
    rdfs:label "Dark Factory" ;
    rdfs:comment "A system where the operator declares desired capabilities and AI agents build, deploy, and operate them with minimal supervision. When the phrase 'dark factory' specifically means software authoring, tighten to ef:ProductFactory; when it specifically means autonomous operations, tighten to ef:PlatformFactory." .

ef:Factory rdf:type owl:Class ;
    rdfs:label "Factory" ;
    rdfs:comment "A maturity ladder for a given domain." .

ef:PlatformFactory rdf:type owl:Class ;
    rdfs:subClassOf ef:DarkFactory ;
    rdfs:subClassOf ef:Factory ;
    rdfs:label "Platform Factory" ;
    rdfs:comment "Operations autonomy — the substrate everything runs on." .

ef:ProductFactory rdf:type owl:Class ;
    rdfs:subClassOf ef:DarkFactory ;
    rdfs:subClassOf ef:Factory ;
    rdfs:label "Product Factory" ;
    rdfs:comment "Development autonomy — software the operator authors." .

ef:Platform rdf:type owl:Class ;
    rdfs:label "Platform" ;
    rdfs:comment "The operational substrate: hardware, network, operating systems, etc. The term 'Infrastructure' is avoided as a top-level organizing term in EposForge; use Platform instead." .

ef:Product rdf:type owl:Class ;
    rdfs:label "Product" ;
    rdfs:comment "Software (or physical workflow) authored by the operator. The term 'Software' is avoided as a top-level term because it cannot cleanly distinguish operator-authored applications (Product) from third-party server apps (Platform)." .

ef:Component rdf:type owl:Class ;
    rdfs:label "Component" ;
    rdfs:comment "An architectural slot in a dark factory. Earlier framings used 'Dev Product Registry' as a component slot; the current model treats the catalog as emergent from installed Adapters per the universal Adapter Pattern." .

ef:Adapter rdf:type owl:Class ;
    rdfs:label "Adapter" ;
    rdfs:comment "A concrete implementation that plugs into a component slot. Every Adapter carries a status (experimental, approved, deprecated, or shelved)." .

ef:ReferenceImplementation rdf:type owl:Class ;
    rdfs:subClassOf ef:Adapter ;
    rdfs:label "Reference Implementation" ;
    rdfs:comment "An Adapter published by the canonical EposForge instance as a worked example for Adopters' agents to consume and adapt. Distinguished from a private repo-instance adapter by being intentionally exposed via MCP. The frontmatter `doc_kind: reference-implementation` on an adapter card is the document-level projection of membership in this class." .

ef:AdapterPattern rdf:type owl:Class ;
    rdfs:label "Adapter Pattern" ;
    rdfs:comment "EposForge's universal plug-in pattern used across components." .

ef:AdapterStatus rdf:type owl:Class ;
    rdfs:label "Adapter Status" ;
    rdfs:comment "The lifecycle state of an Adapter." .

ef:Standard rdf:type owl:Class ;
    rdfs:label "Standard" ;
    rdfs:comment "A cross-cutting normative rule adopted under 04-standards/. Standards govern naming, documentation, tooling conventions, and similar cross-cutting concerns." .

ef:Agent rdf:type owl:Class ;
    rdfs:label "Agent" ;
    rdfs:comment "An autonomous AI-driven executor." .

ef:Spec rdf:type owl:Class ;
    rdfs:label "Spec" ;
    rdfs:comment "A declarative statement of desired capability." .

ef:LivingSpec rdf:type owl:Class ;
    rdfs:subClassOf ef:Spec ;
    rdfs:label "Living Spec" ;
    rdfs:comment "A canonical spec document that lives inside every factory deliverable repo." .

ef:Phase rdf:type owl:Class ;
    rdfs:label "Phase" ;
    rdfs:comment "A stage of factory maturity." .

ef:Pillar rdf:type owl:Class ;
    rdfs:label "Pillar" ;
    rdfs:comment "A foundational architectural axis of the dark factory vision." .

ef:Principle rdf:type owl:Class ;
    rdfs:label "Principle" ;
    rdfs:comment "A guiding rule or norm that steers design and operation." .

ef:Deliverable rdf:type owl:Class ;
    rdfs:label "Deliverable" ;
    rdfs:comment "A software, platform, or physical output produced by a factory." .

ef:Constraint rdf:type owl:Class ;
    rdfs:label "Constraint" ;
    rdfs:comment "A limiting condition that bounds architecture or operations." .

ef:Policy rdf:type owl:Class ;
    rdfs:label "Policy" ;
    rdfs:comment "A machine-enforceable rule that constrains what an agent may do." .

ef:Guardrail rdf:type owl:Class ;
    rdfs:label "Guardrail" ;
    rdfs:comment "A runtime check or approval gate that enforces a policy." .

ef:Operator rdf:type owl:Class ;
    rdfs:label "Operator" ;
    rdfs:comment "The human in charge of a EposForge instance." .

ef:Adopter rdf:type owl:Class ;
    rdfs:label "Adopter" ;
    rdfs:comment "An external party (organization, team, or individual) that adopts the EposForge pattern in their own instance, consuming the ontology and reference implementations via the EposForge MCP. Peer concept to ef:Operator: an Adopter is org-level; an Operator is the human-level role within an Adopter's instance." .

ef:DevProduct rdf:type owl:Class ;
    rdfs:subClassOf ef:Adapter ;
    rdfs:label "Dev Product" ;
    rdfs:comment "A third-party AI coding tool consumed as an executor." .

ef:Router rdf:type owl:Class ;
    rdfs:subClassOf ef:Adapter ;
    rdfs:label "Router" ;
    rdfs:comment "The decomposition and dispatch layer of the Product Factory." .

ef:ToolTransport rdf:type owl:Class ;
    rdfs:subClassOf ef:Adapter ;
    rdfs:label "Tool Transport" ;
    rdfs:comment "The protocol/contract by which Dev Products consume capabilities." .

ef:SpecGraph rdf:type owl:Class ;
    rdfs:subClassOf ef:Adapter ;
    rdfs:label "Spec Graph" ;
    rdfs:comment "A queryable projection of every Living Spec across the factory." .

ef:ExecutionSandbox rdf:type owl:Class ;
    rdfs:subClassOf ef:Adapter ;
    rdfs:label "Execution Sandbox" ;
    rdfs:comment "The isolated runtime in which dispatched Dev Product work executes." .

ef:Migration rdf:type owl:Class ;
    rdfs:label "Migration" ;
    rdfs:comment "A named, in-flight transition between two coexisting architectural shapes (legacy and target) within an instance, with a stated completion commitment." .

### Object Properties (Relationships)

ef:hasComponent rdf:type owl:ObjectProperty ;
    rdfs:label "HAS_COMPONENT" ;
    rdfs:domain ef:DarkFactory ;
    rdfs:range ef:Component .

ef:fulfillsSlot rdf:type owl:ObjectProperty ;
    rdfs:label "FULFILLS_SLOT" ;
    rdfs:domain ef:Adapter ;
    rdfs:range ef:Component .

ef:maturesTo rdf:type owl:ObjectProperty ;
    rdfs:label "MATURES_TO" ;
    rdfs:domain ef:Phase ;
    rdfs:range ef:Phase .

ef:dependsOn rdf:type owl:ObjectProperty ;
    rdfs:label "DEPENDS_ON" .

ef:governedBy rdf:type owl:ObjectProperty ;
    rdfs:label "GOVERNED_BY" .

ef:implements rdf:type owl:ObjectProperty ;
    rdfs:label "IMPLEMENTS" .

ef:hasStatus rdf:type owl:ObjectProperty ;
    rdfs:label "HAS_STATUS" ;
    rdfs:domain ef:Adapter ;
    rdfs:range ef:AdapterStatus .

ef:supersedes rdf:type owl:ObjectProperty ;
    rdfs:label "SUPERSEDES" .

ef:partOf rdf:type owl:ObjectProperty ;
    rdfs:label "PART_OF" .

ef:legacyShapeOf rdf:type owl:ObjectProperty ;
    rdfs:label "LEGACY_SHAPE_OF" ;
    rdfs:range ef:Migration .

ef:targetShapeOf rdf:type owl:ObjectProperty ;
    rdfs:label "TARGET_SHAPE_OF" ;
    rdfs:range ef:Migration .

ef:produces rdf:type owl:ObjectProperty ;
    rdfs:label "PRODUCES" ;
    rdfs:domain ef:Factory ;
    rdfs:range ef:Deliverable .

ef:hasPillar rdf:type owl:ObjectProperty ;
    rdfs:label "HAS_PILLAR" ;
    rdfs:domain ef:DarkFactory ;
    rdfs:range ef:Pillar .

ef:guidedByPrinciple rdf:type owl:ObjectProperty ;
    rdfs:label "GUIDED_BY_PRINCIPLE" ;
    rdfs:domain ef:DarkFactory ;
    rdfs:range ef:Principle .

ef:constrainedBy rdf:type owl:ObjectProperty ;
    rdfs:label "CONSTRAINED_BY" ;
    rdfs:domain ef:Component ;
    rdfs:range ef:Constraint .

ef:usesAdapterPattern rdf:type owl:ObjectProperty ;
    rdfs:label "USES_ADAPTER_PATTERN" ;
    rdfs:domain ef:Component ;
    rdfs:range ef:AdapterPattern .

### Datatype Properties (Adapter Metadata)

ef:adapterName rdf:type owl:DatatypeProperty ;
    rdfs:label "name" ;
    rdfs:comment "Stable identifier of an Adapter within its component slot." ;
    rdfs:domain ef:Adapter ;
    rdfs:range xsd:string .

ef:adapterVersion rdf:type owl:DatatypeProperty ;
    rdfs:label "version" ;
    rdfs:comment "Semver or equivalent version string of an Adapter." ;
    rdfs:domain ef:Adapter ;
    rdfs:range xsd:string .

ef:privacyPosture rdf:type owl:DatatypeProperty ;
    rdfs:label "privacy_posture" ;
    rdfs:comment "One of: local, vendor-no-training, vendor-default." ;
    rdfs:domain ef:Adapter ;
    rdfs:range xsd:string .

ef:costHint rdf:type owl:DatatypeProperty ;
    rdfs:label "cost_hint" ;
    rdfs:comment "Coarse cost tier: free, consumer-paid, commercial, metered, n/a." ;
    rdfs:domain ef:Adapter ;
    rdfs:range xsd:string .

ef:capabilities rdf:type owl:DatatypeProperty ;
    rdfs:label "capabilities" ;
    rdfs:comment "Capability tag declared by an Adapter (multi-valued)." ;
    rdfs:domain ef:Adapter ;
    rdfs:range xsd:string .

ef:invocationSurface rdf:type owl:DatatypeProperty ;
    rdfs:label "invocation_surface" ;
    rdfs:comment "How the Adapter is invoked: CLI, HTTP, library, process, etc." ;
    rdfs:domain ef:Adapter ;
    rdfs:range xsd:string .

### Individuals (The 14 Core Components)

ef:SpecInput rdf:type ef:Component ; rdfs:label "Spec Input" .
ef:LivingSpecComponent rdf:type ef:Component ; rdfs:label "Living Spec" .
ef:DevProductComponent rdf:type ef:Component ; rdfs:label "Dev Product" .
ef:RouterComponent rdf:type ef:Component ; rdfs:label "Router" .
ef:ToolTransportComponent rdf:type ef:Component ; rdfs:label "Tool Transport" .
ef:SpecGraphComponent rdf:type ef:Component ; rdfs:label "Spec Graph" .
ef:ExecutionSandboxComponent rdf:type ef:Component ; rdfs:label "Execution Sandbox" .
ef:AgentPolicyComponent rdf:type ef:Component ; rdfs:label "Agent Policy" .
ef:ReleaseRingsComponent rdf:type ef:Component ; rdfs:label "Release Rings" .
ef:SourceControlCIComponent rdf:type ef:Component ; rdfs:label "Source Control + CI" .
ef:InferenceLayerComponent rdf:type ef:Component ; rdfs:label "Inference Layer" .
ef:AuditObservabilityComponent rdf:type ef:Component ; rdfs:label "Audit & Observability" .
ef:SecretsKeyManagementComponent rdf:type ef:Component ; rdfs:label "Secrets & Key Management" .
ef:BacklogComponent rdf:type ef:Component ; rdfs:label "Backlog" .

### Adapter Status Individuals

ef:AdapterStatusExperimental rdf:type ef:AdapterStatus ;
    rdfs:label "experimental" ;
    rdfs:comment "Adapter is under active development or evaluation." .

ef:AdapterStatusApproved rdf:type ef:AdapterStatus ;
    rdfs:label "approved" ;
    rdfs:comment "Adapter is production-ready and recommended for use." .

ef:AdapterStatusDeprecated rdf:type ef:AdapterStatus ;
    rdfs:label "deprecated" ;
    rdfs:comment "Adapter is no longer recommended and may be removed." .

ef:AdapterStatusShelved rdf:type ef:AdapterStatus ;
    rdfs:label "shelved" ;
    rdfs:comment "Adapter is not being worked on but retained for possible future reactivation. Agents MUST NOT select or invoke shelved adapters." .

### Platform Factory Phase Individuals

ef:PlatformPhase0 rdf:type ef:Phase ;
    rdfs:label "Phase 0: Foundation" ;
    rdfs:comment "Everything-as-Code plus observability." ;
    ef:maturesTo ef:PlatformPhase1 .

ef:PlatformPhase1 rdf:type ef:Phase ;
    rdfs:label "Phase 1: Agent Observation" ;
    rdfs:comment "Agents query, propose, wait." ;
    ef:maturesTo ef:PlatformPhase2 .

ef:PlatformPhase2 rdf:type ef:Phase ;
    rdfs:label "Phase 2: Agent Proposals" ;
    rdfs:comment "Agents open PRs, humans review and apply." ;
    ef:maturesTo ef:PlatformPhase3 .

ef:PlatformPhase3 rdf:type ef:Phase ;
    rdfs:label "Phase 3: Supervised Autonomy" ;
    rdfs:comment "Agents execute pre-approved actions." ;
    ef:maturesTo ef:PlatformPhase4 .

ef:PlatformPhase4 rdf:type ef:Phase ;
    rdfs:label "Phase 4: Full Autonomy" ;
    rdfs:comment "Agents self-update, coordinate, optimize." .

### Product Factory Phase Individuals

ef:ProductPhaseA rdf:type ef:Phase ;
    rdfs:label "Phase A: Registry as ground truth" ;
    ef:maturesTo ef:ProductPhaseB .

ef:ProductPhaseB rdf:type ef:Phase ;
    rdfs:label "Phase B: Tool transport foundation" ;
    ef:maturesTo ef:ProductPhaseC .

ef:ProductPhaseC rdf:type ef:Phase ;
    rdfs:label "Phase C: Living Spec rollout" ;
    ef:maturesTo ef:ProductPhaseD .

ef:ProductPhaseD rdf:type ef:Phase ;
    rdfs:label "Phase D: Router v0" ;
    ef:maturesTo ef:ProductPhaseE .

ef:ProductPhaseE rdf:type ef:Phase ;
    rdfs:label "Phase E: Spec Graph" ;
    ef:maturesTo ef:ProductPhaseF .

ef:ProductPhaseF rdf:type ef:Phase ;
    rdfs:label "Phase F: Level 5 gate" ;
    rdfs:comment "Auto-merge tier-1 changes." .

### Standard Individuals

ef:StandardsMeta rdf:type ef:Standard ;
    rdfs:label "Standards Meta" ;
    rdfs:comment "Adopted standard governing the shape, status, and conformance language of all other standards under 04-standards/." .

ef:NamingConventions rdf:type ef:Standard ;
    rdfs:label "Naming Conventions" ;
    rdfs:comment "Adopted standard governing repo-wide naming (files, directories, identifiers)." .

ef:ResearchMirror rdf:type ef:Standard ;
    rdfs:label "Research Mirror" ;
    rdfs:comment "Adopted standard governing how external research is mirrored into the repo." .

### Vision Pillar Individuals

ef:PillarSubstrateAgnosticPlatform rdf:type ef:Pillar ;
    rdfs:label "Substrate-Agnostic Platform" ;
    rdfs:comment "The dark-factory pattern is substrate-agnostic across software, platform, and future physical execution environments." .

ef:PillarAIFactory rdf:type ef:Pillar ;
    rdfs:label "AI Factory" ;
    rdfs:comment "Agentic execution is the default operating model across factory workflows." .

ef:PillarProductEngine rdf:type ef:Pillar ;
    rdfs:label "Product Engine" ;
    rdfs:comment "The factory produces durable deliverables with Living Specs and Spec Graph projection." .

### Core Principle Individuals

ef:PrincipleEverythingAsCode rdf:type ef:Principle ;
    rdfs:label "Everything-as-Code" ;
    rdfs:comment "Git is source of truth; no manual clicks." .

ef:PrincipleAIFirstOperations rdf:type ef:Principle ;
    rdfs:label "AI-First Operations" ;
    rdfs:comment "Agents observe, reason, and act; humans set policy and audit." .

ef:PrincipleDefenseInDepth rdf:type ef:Principle ;
    rdfs:label "Defense in Depth" ;
    rdfs:comment "Assume breach and limit blast radius with layered safeguards." .

ef:PrincipleIncrementalComplexity rdf:type ef:Principle ;
    rdfs:label "Incremental Complexity" ;
    rdfs:comment "Start simple and add layers as needed." .

ef:PrincipleCloudAgnostic rdf:type ef:Principle ;
    rdfs:label "Cloud-Agnostic" ;
    rdfs:comment "Workloads remain portable across environments." .

ef:PrincipleObservableAndTestable rdf:type ef:Principle ;
    rdfs:label "Observable and Testable" ;
    rdfs:comment "State changes are observable and configurations are validated." .

### Pattern Individual and Top-Level Relationship Assertions

ef:EposForgePattern rdf:type ef:DarkFactory ;
    rdfs:label "EposForge Pattern" ;
    ef:hasPillar ef:PillarSubstrateAgnosticPlatform, ef:PillarAIFactory, ef:PillarProductEngine ;
    ef:guidedByPrinciple ef:PrincipleEverythingAsCode, ef:PrincipleAIFirstOperations, ef:PrincipleDefenseInDepth,
        ef:PrincipleIncrementalComplexity, ef:PrincipleCloudAgnostic, ef:PrincipleObservableAndTestable .

ef:UniversalAdapterPattern rdf:type ef:AdapterPattern ;
    rdfs:label "Universal Adapter Pattern" ;
    rdfs:comment "The universal Adapter Pattern applied across EposForge components." .

ef:SpecInputComponent ef:usesAdapterPattern ef:UniversalAdapterPattern .
ef:LivingSpecComponent ef:usesAdapterPattern ef:UniversalAdapterPattern .
ef:DevProductComponent ef:usesAdapterPattern ef:UniversalAdapterPattern .
ef:RouterComponent ef:usesAdapterPattern ef:UniversalAdapterPattern .
ef:ToolTransportComponent ef:usesAdapterPattern ef:UniversalAdapterPattern .
ef:SpecGraphComponent ef:usesAdapterPattern ef:UniversalAdapterPattern .
ef:ExecutionSandboxComponent ef:usesAdapterPattern ef:UniversalAdapterPattern .
ef:AgentPolicyComponent ef:usesAdapterPattern ef:UniversalAdapterPattern .
ef:SourceControlCIComponent ef:usesAdapterPattern ef:UniversalAdapterPattern .
ef:InferenceLayerComponent ef:usesAdapterPattern ef:UniversalAdapterPattern .
ef:AuditObservabilityComponent ef:usesAdapterPattern ef:UniversalAdapterPattern .
ef:SecretsKeyManagementComponent ef:usesAdapterPattern ef:UniversalAdapterPattern .
ef:BacklogComponent ef:usesAdapterPattern ef:UniversalAdapterPattern .
ef:ReleaseRingsComponent ef:usesAdapterPattern ef:UniversalAdapterPattern .
