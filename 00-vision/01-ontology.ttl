### Platform Factory Phase Individuals

ef:PlatformPhase0 rdf:type ef:Phase, skos:Concept ;
    rdfs:label "Phase 0: Foundation" ;
    skos:prefLabel "Phase 0: Foundation" ;
    skos:definition "Everything-as-Code plus observability." ;
    skos:inScheme ef:KnowledgeTree ;
    ef:maturesTo ef:PlatformPhase1 .

ef:PlatformPhase1 rdf:type ef:Phase, skos:Concept ;
    rdfs:label "Phase 1: Agent Observation" ;
    skos:prefLabel "Phase 1: Agent Observation" ;
    skos:definition "Agents query, propose, wait." ;
    skos:inScheme ef:KnowledgeTree ;
    ef:maturesTo ef:PlatformPhase2 .

ef:PlatformPhase2 rdf:type ef:Phase, skos:Concept ;
    rdfs:label "Phase 2: Agent Proposals" ;
    skos:prefLabel "Phase 2: Agent Proposals" ;
    skos:definition "Agents open PRs, humans review and apply." ;
    skos:inScheme ef:KnowledgeTree ;
    ef:maturesTo ef:PlatformPhase3 .

ef:PlatformPhase3 rdf:type ef:Phase, skos:Concept ;
    rdfs:label "Phase 3: Supervised Autonomy" ;
    skos:prefLabel "Phase 3: Supervised Autonomy" ;
    skos:definition "Maturity rung (irreversible, reached via ef:maturesTo): agents execute pre-approved actions. For the reversible operating posture at this level, see ef:AutonomyModeSupervised." ;
    skos:inScheme ef:KnowledgeTree ;
    ef:maturesTo ef:PlatformPhase4 .

ef:PlatformPhase4 rdf:type ef:Phase, skos:Concept ;
    rdfs:label "Phase 4: Full Autonomy" ;
    skos:prefLabel "Phase 4: Full Autonomy" ;
    skos:definition "Maturity rung (irreversible, reached via ef:maturesTo): agents self-update, coordinate, optimize. For the reversible operating posture at this level, see ef:AutonomyModeAutonomous." ;
    skos:inScheme ef:KnowledgeTree ;
    ef:maturesTo ef:PlatformPhase5 .

