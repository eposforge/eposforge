@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix ef: <http://eposforge.org/ontology/> .

ef:Ontology rdf:type owl:Ontology ;
    rdfs:label "EposForge Dark Factory Ontology" ;
    rdfs:comment """Domain ontology (OWL) + knowledge taxonomy (SKOS) for the EposForge dark factory pattern.
The domain model defines the pattern (Component, Adapter, fulfillsSlot, etc.).
The taxonomy organizes the knowledge tree for navigation.
Adopter agents accessing via the EposForge Cognee MCP should prefer SKOS relations (inScheme, broader, prefLabel) for knowledge structure queries and start with recall of 'EposForge MCP usage'.
Source of truth: this file. See maintain-ontology skill for editorial workflow and usage patterns.""" .

### Classes

ef:DarkFactory rdf:type owl:Class ;
    rdfs:label "Dark Factory" ;
    rdfs:comment "A system where the operator declares desired capabilities and AI agents build, deploy, and operate them with minimal supervision. When the phrase 'dark factory' specifically means software authoring, tighten to ef:ProductFactory; when it specifically means autonomous operations, tighten to ef:PlatformFactory." .

ef:Factory rdf:type owl:Class ;
    rdfs:label "Factory" ;
    rdfs:comment "A maturity ladder for a given domain." .

ef:PlatformFactory rdf:type owl:Class ;
    rdfs:subClassOf ef:DarkFactory ;
    rdfs:subClassOf ef:Factory ;
    rdfs:label "Platform Factory" ;
    rdfs:comment "Operations autonomy — the substrate everything runs on." .

ef:ProductFactory rdf:type owl:Class ;
    rdfs:subClassOf ef:DarkFactory ;
    rdfs:subClassOf ef:Factory ;
    rdfs:label "Product Factory" ;
    rdfs:comment "Development autonomy — software the operator authors." .

ef:Platform rdf:type owl:Class ;
    rdfs:label "Platform" ;
    rdfs:comment "The operational substrate: hardware, network, operating systems, etc. The term 'Infrastructure' is avoided as a top-level organizing term in EposForge; use Platform instead." .

ef:Product rdf:type owl:Class ;
    rdfs:label "Product" ;
    rdfs:comment "Software (or physical workflow) authored by the operator. The term 'Software' is avoided as a top-level term because it cannot cleanly distinguish operator-authored applications (Product) from third-party server apps (Platform)." .

ef:Component rdf:type owl:Class ;
    rdfs:label "Component" ;
    rdfs:comment "An architectural slot in a dark factory. Earlier framings used 'Dev Product Registry' as a component slot; the current model treats the catalog as emergent from installed Adapters per the universal Adapter Pattern." .

ef:Adapter rdf:type owl:Class ;
    rdfs:label "Adapter" ;
    rdfs:comment "A concrete implementation that plugs into a component slot. Every Adapter carries a status (experimental, approved, deprecated, or shelved)." .

ef:ReferenceImplementation rdf:type owl:Class ;
    rdfs:subClassOf ef:Adapter ;
    rdfs:label "Reference Implementation" ;
    rdfs:comment "An Adapter published by the canonical EposForge instance as a worked example for Adopters' agents to consume and adapt. Distinguished from a private repo-instance adapter by being intentionally exposed via MCP. The frontmatter `doc_kind: reference-implementation` on an adapter card is the document-level projection of membership in this class." .

ef:AdapterPattern rdf:type owl:Class ;
    rdfs:label "Adapter Pattern" ;
    rdfs:comment "EposForge's universal plug-in pattern used across components." .

ef:AdapterStatus rdf:type owl:Class ;
    rdfs:label "Adapter Status" ;
    rdfs:comment "The lifecycle state of an Adapter." .

ef:Standard rdf:type owl:Class ;
    rdfs:label "Standard" ;
    rdfs:comment "A cross-cutting normative rule adopted under 04-standards/. Standards govern naming, documentation, tooling conventions, and similar cross-cutting concerns." .

ef:Agent rdf:type owl:Class ;
    rdfs:label "Agent" ;
    rdfs:comment "An autonomous AI-driven executor." .

ef:Spec rdf:type owl:Class ;
    rdfs:label "Spec" ;
    rdfs:comment "A declarative statement of desired capability." .

ef:LivingSpec rdf:type owl:Class ;
    rdfs:subClassOf ef:Spec ;
    rdfs:label "Living Spec" ;
    rdfs:comment "A canonical spec document that lives inside every factory deliverable repo." .

ef:Phase rdf:type owl:Class ;
    rdfs:label "Phase" ;
    rdfs:comment "A stage of factory maturity." .

ef:Pillar rdf:type owl:Class ;
    rdfs:label "Pillar" ;
    rdfs:comment "A foundational architectural axis of the dark factory vision." .

ef:Principle rdf:type owl:Class ;
    rdfs:label "Principle" ;
    rdfs:comment "A guiding rule or norm that steers design and operation." .

ef:Deliverable rdf:type owl:Class ;
    rdfs:label "Deliverable" ;
    rdfs:comment "A software, platform, or physical output produced by a factory." .

ef:Constraint rdf:type owl:Class ;
    rdfs:label "Constraint" ;
    rdfs:comment "A limiting condition that bounds architecture or operations." .

ef:Policy rdf:type owl:Class ;
    rdfs:label "Policy" ;
    rdfs:comment "A machine-enforceable rule that constrains what an agent may do." .

ef:Guardrail rdf:type owl:Class ;
    rdfs:label "Guardrail" ;
    rdfs:comment "A runtime check or approval gate that enforces a policy." .

ef:Operator rdf:type owl:Class ;
    rdfs:label "Operator" ;
    rdfs:comment "The human in charge of a EposForge instance." .

ef:Adopter rdf:type owl:Class ;
    rdfs:label "Adopter" ;
    rdfs:comment "An external party (organization, team, or individual) that adopts the EposForge pattern in their own instance, consuming the ontology and reference implementations via the EposForge MCP. Peer concept to ef:Operator: an Adopter is org-level; an Operator is the human-level role within an Adopter's instance." .

ef:DevProduct rdf:type owl:Class ;
    rdfs:subClassOf ef:Adapter ;
    rdfs:label "Dev Product" ;
    rdfs:comment "A third-party AI coding tool consumed as an executor." .

ef:Router rdf:type owl:Class ;
    rdfs:subClassOf ef:Adapter ;
    rdfs:label "Router" ;
    rdfs:comment "The decomposition and dispatch layer of the Product Factory." .

ef:ToolTransport rdf:type owl:Class ;
    rdfs:subClassOf ef:Adapter ;
    rdfs:label "Tool Transport" ;
    rdfs:comment "The protocol/contract by which Dev Products consume capabilities." .

ef:SpecGraph rdf:type owl:Class ;
    rdfs:subClassOf ef:Adapter ;
    rdfs:label "Spec Graph" ;
    rdfs:comment "A queryable projection of every Living Spec across the factory." .

ef:ExecutionSandbox rdf:type owl:Class ;
    rdfs:subClassOf ef:Adapter ;
    rdfs:label "Execution Sandbox" ;
    rdfs:comment "The isolated runtime in which dispatched Dev Product work executes." .

ef:SpecInputAdapter rdf:type owl:Class ;
    rdfs:subClassOf ef:Adapter ;
    rdfs:label "Spec Input Adapter" ;
    rdfs:comment "An Adapter kind that fulfills the Spec Input component slot." .

ef:LivingSpecAdapter rdf:type owl:Class ;
    rdfs:subClassOf ef:Adapter ;
    rdfs:label "Living Spec Adapter" ;
    rdfs:comment "An Adapter kind that fulfills the Living Spec component slot." .

ef:AgentPolicyAdapter rdf:type owl:Class ;
    rdfs:subClassOf ef:Adapter ;
    rdfs:label "Agent Policy Adapter" ;
    rdfs:comment "An Adapter kind that fulfills the Agent Policy component slot." .

ef:ReleaseRingsAdapter rdf:type owl:Class ;
    rdfs:subClassOf ef:Adapter ;
    rdfs:label "Release Rings Adapter" ;
    rdfs:comment "An Adapter kind that fulfills the Release Rings component slot." .

ef:SourceControlCIAdapter rdf:type owl:Class ;
    rdfs:subClassOf ef:Adapter ;
    rdfs:label "Source Control + CI Adapter" ;
    rdfs:comment "An Adapter kind that fulfills the Source Control + CI component slot." .

ef:InferenceLayerAdapter rdf:type owl:Class ;
    rdfs:subClassOf ef:Adapter ;
    rdfs:label "Inference Layer Adapter" ;
    rdfs:comment "An Adapter kind that fulfills the Inference Layer component slot." .

ef:AuditObservabilityAdapter rdf:type owl:Class ;
    rdfs:subClassOf ef:Adapter ;
    rdfs:label "Audit and Observability Adapter" ;
    rdfs:comment "An Adapter kind that fulfills the Audit and Observability component slot." .

ef:SecretsKeyManagementAdapter rdf:type owl:Class ;
    rdfs:subClassOf ef:Adapter ;
    rdfs:label "Secrets and Key Management Adapter" ;
    rdfs:comment "An Adapter kind that fulfills the Secrets and Key Management component slot." .

ef:BacklogAdapter rdf:type owl:Class ;
    rdfs:subClassOf ef:Adapter ;
    rdfs:label "Backlog Adapter" ;
    rdfs:comment "An Adapter kind that fulfills the Backlog component slot." .

ef:Migration rdf:type owl:Class ;
    rdfs:label "Migration" ;
    rdfs:comment "A named, in-flight transition between two coexisting architectural shapes (legacy and target) within an instance, with a stated completion commitment." .

### Knowledge-Tree Node Kinds

ef:Group rdf:type owl:Class ;
    rdfs:label "Group" ;
    rdfs:comment "An organizational sub-container in the canonical knowledge tree. Provides grouping for related items but is not load-bearing; the parent remains valid without it. Examples: ai systems, standards, data architecture, value streams." .

ef:Concept rdf:type owl:Class ;
    rdfs:label "Concept" ;
    rdfs:comment "A defined term: a word that names something the factory deals with and carries a canonical adopted definition. A concept is a noun, not a how-to. Not itself implemented; a component adapter may enforce or realize it. Has a lifecycle distinct from components. Authoritative definition lives in this TTL. Examples: living spec, release rings, ontology, agent policy, naming conventions." .

ef:Guidance rdf:type owl:Class ;
    rdfs:label "Guidance" ;
    rdfs:comment "A how-to document: an essay or playbook that helps an agent or human make a decision or carry out a methodology. Not a defined term and not enforced — it is consulted and applied. Where a Concept is a word, a Guidance node is the prose that tells you how to choose or act. Examples: language choice guidance, runtime target guidance, adoption strategy." .

ef:Tenet rdf:type owl:Class ;
    rdfs:label "Tenet" ;
    rdfs:comment "A governing rule or principle — doctrine the factory operates under. Normative: do this / choose this way. Distinct from ef:Concept (a term) and from ef:Guidance (a how-to essay). The constitution is the set of Tenets. Examples: serve adopters by grounding their agents, plan where known iterate where unknown, one canonical tree many projected views." .

### Node Kind Discriminator (Knowledge Tree Taxonomy)

# The node kinds form the taxonomic classification system for the canonical knowledge tree.
# We model this using both OWL (for the discriminator) and SKOS (for concept organization, labels, and future hierarchy via broader/narrower).
# This separation lets us use OWL for the dark factory domain model while using SKOS for organizing knowledge items.

ef:KnowledgeTree rdf:type skos:ConceptScheme ;
    skos:prefLabel "EposForge Canonical Knowledge Tree" ;
    skos:definition "The structured taxonomy of EposForge knowledge: pillars and groups for architecture, plus concepts, guidance, and tenets with explicit definitions and relationships. Governed by the ontology and taxonomy policy." ;
    skos:scopeNote """For agents using the EposForge Cognee MCP: prefer SKOS relations (skos:inScheme, skos:broader, skos:prefLabel) when navigating knowledge structure and hierarchy. Use ef:kind and OWL classes/properties when working with the dark factory pattern semantics (e.g. fulfillsSlot, maturesTo).
Start navigation with recall("EposForge MCP usage") or recall on this scheme's label.
See ef:EposForgeMCPUsage for current recommended query patterns and access model.""" ;
    skos:related ef:EposForgeMCPUsage .

ef:NodeKind rdf:type owl:Class, skos:ConceptScheme ;
    rdfs:label "Node Kind" ;
    skos:prefLabel "Node Kind" ;
    skos:inScheme ef:KnowledgeTree ;
    skos:scopeNote "This is the root discriminator for the knowledge taxonomy. Agents should use the SKOS view (inScheme, prefLabel) for navigation. The ef:kind property connects domain instances to these kinds." ;
    rdfs:comment "A discriminator classifying what a node IS in the canonical knowledge tree. Kind is structural identity, not file type or representation. Allowed values: pillar, group, component, concept, guidance, tenet. This is the root of the knowledge taxonomy." .

ef:NodeKindPillar rdf:type ef:NodeKind, skos:Concept ;
    rdfs:label "pillar" ;
    skos:prefLabel "pillar" ;
    skos:definition "Load-bearing structural division. Essential to the meaning of its parent; the parent could not be what it is without each pillar." ;
    rdfs:comment "Load-bearing structural division. Essential to the meaning of its parent; the parent could not be what it is without each pillar." .

ef:NodeKindGroup rdf:type ef:NodeKind, skos:Concept ;
    rdfs:label "group" ;
    skos:prefLabel "group" ;
    skos:definition "Organizational sub-container. Provides grouping for related items but is not itself load-bearing." ;
    rdfs:comment "Organizational sub-container. Provides grouping for related items but is not itself load-bearing." .

ef:NodeKindComponent rdf:type ef:NodeKind, skos:Concept ;
    rdfs:label "component" ;
    skos:prefLabel "component" ;
    skos:definition "Operational subsystem of the factory. Filled by one or more Adapters via the Adapter Pattern." ;
    rdfs:comment "Operational subsystem of the factory. Filled by one or more Adapters via the Adapter Pattern." .

ef:NodeKindConcept rdf:type ef:NodeKind, skos:Concept ;
    rdfs:label "concept" ;
    skos:prefLabel "concept" ;
    skos:definition "A defined term carrying a canonical adopted definition. The ontology TTL is the authoritative home." ;
    rdfs:comment "A defined term carrying a canonical adopted definition. The ontology TTL is the authoritative home." .

ef:NodeKindGuidance rdf:type ef:NodeKind, skos:Concept ;
    rdfs:label "guidance" ;
    skos:prefLabel "guidance" ;
    skos:definition "A how-to document: essay or playbook consulted and applied by agents and humans." ;
    rdfs:comment "A how-to document: essay or playbook consulted and applied by agents and humans." .

ef:NodeKindTenet rdf:type ef:NodeKind, skos:Concept ;
    rdfs:label "tenet" ;
    skos:prefLabel "tenet" ;
    skos:definition "A governing rule or principle — doctrine the factory operates under. Normative." ;
    rdfs:comment "A governing rule or principle — doctrine the factory operates under. Normative." .

# Example: future use of SKOS hierarchy (add skos:broader between specific knowledge items when modeling the tree structure).
# ef:SomeConcept skos:broader ef:SomeBroaderConcept .

### Lifecycle Status

ef:LifecycleStatus rdf:type owl:Class ;
    rdfs:label "Lifecycle Status" ;
    rdfs:comment "The lifecycle state of a Concept, Guidance, or Tenet node. Distinct from ef:AdapterStatus which governs Adapters." .

### Component Implementation Maturity

ef:ComponentMaturity rdf:type owl:Class ;
    rdfs:label "Component Maturity" ;
    rdfs:comment "The implementation maturity of a Component slot. Answers 'is this component actually running?' Distinct from ef:AdapterStatus (which grades individual Adapter quality). Agents MUST check this before citing a component's patterns as operational. Values: shipped = production-ready adapter installed and running; partial = adapter exists but experimental, platform-specific, or covers only a subset of the contract; intent = component is designed but no functional adapter is installed — treat as design intent only." .

ef:MaturityShipped rdf:type ef:ComponentMaturity ;
    rdfs:label "shipped" ;
    rdfs:comment "At least one functional adapter is installed and running. Agents may cite patterns from this component as currently operational." .

ef:MaturityPartial rdf:type ef:ComponentMaturity ;
    rdfs:label "partial" ;
    rdfs:comment "An adapter exists but is experimental, platform-specific, or covers only part of the component contract. Agents should qualify recommendations with the adapter's scope and limitations." .

ef:MaturityIntent rdf:type ef:ComponentMaturity ;
    rdfs:label "intent" ;
    rdfs:comment "Component slot is defined and designed but no functional installed adapter exists in this instance. Agents MUST NOT present patterns from this component as currently operational — they are design intent only." .

ef:StatusProposed rdf:type ef:LifecycleStatus ;
    rdfs:label "proposed" ;
    rdfs:comment "Term or rule is under consideration; not yet adopted for use across the factory." .

ef:StatusAdopted rdf:type ef:LifecycleStatus ;
    rdfs:label "adopted" ;
    rdfs:comment "Term or rule is accepted and in active use across the factory." .

ef:StatusRetired rdf:type ef:LifecycleStatus ;
    rdfs:label "retired" ;
    rdfs:comment "Term or rule was adopted but is no longer in use. Retained for historical reference." .

### Autonomy Mode

ef:AutonomyMode rdf:type owl:Class ;
    rdfs:label "Autonomy Mode" ;
    rdfs:comment "The operating posture of a factory with respect to human presence in the execution loop: how autonomously it runs at a given moment, selected per instance and reversible. Gated by Dev Product terms of service and by trust calibration. Distinct from ef:Phase: a Phase is an irreversible maturity rung reached via ef:maturesTo, whereas a Mode is a posture the operator can set and unset. Allowed values: supervised, autonomous." .

ef:AutonomyModeSupervised rdf:type ef:AutonomyMode ;
    rdfs:label "supervised" ;
    rdfs:comment "Human on the loop: a near-autonomous fleet runs while a human observes and intervenes by exception. Subscription/OAuth-authenticated Dev Products are permitted here. The operating-posture counterpart of the Platform maturity rung ef:PlatformPhase3, not the same node." ;
    rdfs:seeAlso ef:PlatformPhase3 .

ef:AutonomyModeAutonomous rdf:type ef:AutonomyMode ;
    rdfs:label "autonomous" ;
    rdfs:comment "Human off the loop: no human in the critical path (the dark-factory end state). ToS-restricted Dev Products require BYOK / API-key auth here. The operating-posture counterpart of the Platform maturity rung ef:PlatformPhase4, not the same node." ;
    rdfs:seeAlso ef:PlatformPhase4 .

### Object Properties (Relationships)

ef:hasComponent rdf:type owl:ObjectProperty ;
    rdfs:label "HAS_COMPONENT" ;
    rdfs:domain ef:DarkFactory ;
    rdfs:range ef:Component .

ef:fulfillsSlot rdf:type owl:ObjectProperty ;
    rdfs:label "FULFILLS_SLOT" ;
    rdfs:domain ef:Adapter ;
    rdfs:range ef:Component .

ef:maturesTo rdf:type owl:ObjectProperty ;
    rdfs:label "MATURES_TO" ;
    rdfs:domain ef:Phase ;
    rdfs:range ef:Phase .

ef:dependsOn rdf:type owl:ObjectProperty ;
    rdfs:label "DEPENDS_ON" .

ef:governedBy rdf:type owl:ObjectProperty ;
    rdfs:label "GOVERNED_BY" .

ef:implements rdf:type owl:ObjectProperty ;
    rdfs:label "IMPLEMENTS" .

ef:hasStatus rdf:type owl:ObjectProperty ;
    rdfs:label "HAS_STATUS" ;
    rdfs:domain ef:Adapter ;
    rdfs:range ef:AdapterStatus .

ef:adoptsFrom rdf:type owl:ObjectProperty ;
    rdfs:label "ADOPTS_FROM" ;
    rdfs:domain ef:Adapter ;
    rdfs:range ef:ReferenceImplementation .

ef:supersedes rdf:type owl:ObjectProperty ;
    rdfs:label "SUPERSEDES" .

ef:partOf rdf:type owl:ObjectProperty ;
    rdfs:label "PART_OF" .

ef:legacyShapeOf rdf:type owl:ObjectProperty ;
    rdfs:label "LEGACY_SHAPE_OF" ;
    rdfs:range ef:Migration .

ef:targetShapeOf rdf:type owl:ObjectProperty ;
    rdfs:label "TARGET_SHAPE_OF" ;
    rdfs:range ef:Migration .

ef:produces rdf:type owl:ObjectProperty ;
    rdfs:label "PRODUCES" ;
    rdfs:domain ef:Factory ;
    rdfs:range ef:Deliverable .

ef:hasPillar rdf:type owl:ObjectProperty ;
    rdfs:label "HAS_PILLAR" ;
    rdfs:domain ef:DarkFactory ;
    rdfs:range ef:Pillar .

ef:guidedByPrinciple rdf:type owl:ObjectProperty ;
    rdfs:label "GUIDED_BY_PRINCIPLE" ;
    rdfs:domain ef:DarkFactory ;
    rdfs:range ef:Principle .

ef:constrainedBy rdf:type owl:ObjectProperty ;
    rdfs:label "CONSTRAINED_BY" ;
    rdfs:domain ef:Component ;
    rdfs:range ef:Constraint .

ef:usesAdapterPattern rdf:type owl:ObjectProperty ;
    rdfs:label "USES_ADAPTER_PATTERN" ;
    rdfs:domain ef:Component ;
    rdfs:range ef:AdapterPattern .

ef:kind rdf:type owl:ObjectProperty ;
    rdfs:label "KIND" ;
    rdfs:range ef:NodeKind ;
    rdfs:comment "Discriminator declaring a node's kind in the canonical knowledge tree (pillar|group|component|concept|guidance|tenet)." .

ef:lifecycleStatus rdf:type owl:ObjectProperty ;
    rdfs:label "LIFECYCLE_STATUS" ;
    rdfs:range ef:LifecycleStatus ;
    rdfs:comment "Lifecycle status of a Concept, Guidance, or Tenet (proposed|adopted|retired). Distinct from ef:hasStatus which governs Adapters." .

ef:componentMaturity rdf:type owl:ObjectProperty ;
    rdfs:label "COMPONENT_MATURITY" ;
    rdfs:domain ef:Component ;
    rdfs:range ef:ComponentMaturity ;
    rdfs:comment "Implementation maturity of a Component slot (shipped|partial|intent). Agents must check this before citing a component's patterns as operational. intent = design only." .

ef:operatesInMode rdf:type owl:ObjectProperty ;
    rdfs:label "OPERATES_IN_MODE" ;
    rdfs:domain ef:Factory ;
    rdfs:range ef:AutonomyMode ;
    rdfs:comment "The autonomy mode a factory currently operates in. A reversible operating posture, distinct from the factory's ef:Phase maturity." .

### Datatype Properties (Adapter Metadata)

ef:adapterName rdf:type owl:DatatypeProperty ;
    rdfs:label "name" ;
    rdfs:comment "Stable identifier of an Adapter within its component slot." ;
    rdfs:domain ef:Adapter ;
    rdfs:range xsd:string .

ef:adapterVersion rdf:type owl:DatatypeProperty ;
    rdfs:label "version" ;
    rdfs:comment "Semver or equivalent version string of an Adapter." ;
    rdfs:domain ef:Adapter ;
    rdfs:range xsd:string .

ef:privacyPosture rdf:type owl:DatatypeProperty ;
    rdfs:label "privacy_posture" ;
    rdfs:comment "One of: local, vendor-no-training, vendor-default." ;
    rdfs:domain ef:Adapter ;
    rdfs:range xsd:string .

ef:costHint rdf:type owl:DatatypeProperty ;
    rdfs:label "cost_hint" ;
    rdfs:comment "Coarse cost tier: free, consumer-paid, commercial, metered, n/a." ;
    rdfs:domain ef:Adapter ;
    rdfs:range xsd:string .

ef:capabilities rdf:type owl:DatatypeProperty ;
    rdfs:label "capabilities" ;
    rdfs:comment "Capability tag declared by an Adapter (multi-valued)." ;
    rdfs:domain ef:Adapter ;
    rdfs:range xsd:string .

ef:invocationSurface rdf:type owl:DatatypeProperty ;
    rdfs:label "invocation_surface" ;
    rdfs:comment "How the Adapter is invoked: CLI, HTTP, library, process, etc." ;
    rdfs:domain ef:Adapter ;
    rdfs:range xsd:string .

ef:autonomyTosPosture rdf:type owl:DatatypeProperty ;
    rdfs:label "autonomy_tos_posture" ;
    rdfs:comment "The highest ef:AutonomyMode an Adapter's licensing/terms of service permit, expressed as a threshold string. Examples: byok-clean-all-modes; subscription-ok-through-supervised|api-key-required-for-autonomous; supervised-max. A factory operating in autonomous mode must not dispatch to an Adapter whose posture forbids it." ;
    rdfs:domain ef:Adapter ;
    rdfs:range xsd:string .

### Datatype Properties (Concept / Guidance / Tenet Schemas)

ef:adoptedDefinition rdf:type owl:DatatypeProperty ;
    rdfs:label "adopted_definition" ;
    rdfs:comment "The canonical one-sentence definition of a Concept, as adopted into the ontology. This is the definition agents and adopters rely on." ;
    rdfs:domain ef:Concept ;
    rdfs:range xsd:string .

ef:statement rdf:type owl:DatatypeProperty ;
    rdfs:label "statement" ;
    rdfs:comment "The normative statement of a Tenet, expressed as a short imperative or declarative doctrine." ;
    rdfs:domain ef:Tenet ;
    rdfs:range xsd:string .

ef:variants rdf:type owl:DatatypeProperty ;
    rdfs:label "variants" ;
    rdfs:comment "Alternative phrasings or related names for a Concept (multi-valued string)." ;
    rdfs:domain ef:Concept ;
    rdfs:range xsd:string .

ef:relationshipEdge rdf:type owl:DatatypeProperty ;
    rdfs:label "relationship_edge" ;
    rdfs:comment "A typed relationship edge expression for a Concept, expressed as a string in the form KEYWORD:target (e.g. IMPLEMENTS:ef:LivingSpecAdapter). Multi-valued." ;
    rdfs:domain ef:Concept ;
    rdfs:range xsd:string .

### Knowledge-Tree Individuals

ef:EposForgeMCPUsage rdf:type ef:Guidance, skos:Concept ;
    rdfs:label "EposForge MCP usage" ;
    skos:prefLabel "EposForge MCP usage" ;
    skos:definition """Adopter agents should start here. The EposForge Spec Graph is exposed via the Cognee MCP (recall, graph queries).
Preferred access: Use SKOS (skos:inScheme on ef:KnowledgeTree, skos:broader/narrower, skos:prefLabel) for knowledge tree navigation and classification.
Use OWL domain model (ef:kind, ef:fulfillsSlot, ef:maturesTo, etc.) for the dark factory pattern itself.
Always begin with recall("EposForge MCP usage") or recall("EposForge Canonical Knowledge Tree").
See the scopeNote on ef:KnowledgeTree for current access model. This node is the canonical entry point for proper MCP usage.""" ;
    skos:inScheme ef:KnowledgeTree ;
    ef:kind ef:NodeKindGuidance ;
    ef:lifecycleStatus ef:StatusAdopted .

ef:RandianConceptFormation rdf:type ef:Tenet, skos:Concept ;
    rdfs:label "Randian concept formation" ;
    skos:prefLabel "Randian concept formation" ;
    skos:altLabel "Objectivist concept formation", "Randian epistemology" ;
    skos:definition "The engineering-relevant doctrine adopted by EposForge for ontology editing: select terms by explanatory roots rather than surface similarities. Included as governing editorial doctrine for the canonical ontology, not as an attempt to model Objectivism in full." ;
    rdfs:comment "The engineering-relevant doctrine adopted by EposForge for ontology editing: select terms by explanatory roots rather than surface similarities. Included as governing editorial doctrine for the canonical ontology, not as an attempt to model Objectivism in full." ;
    ef:statement "Form ontology terms around the deepest available explanatory characteristic, using context-aware abstraction rather than surface resemblance." ;
    ef:variants "Objectivist concept formation", "Randian epistemology" ;
    ef:kind ef:NodeKindTenet ;
    ef:lifecycleStatus ef:StatusAdopted .

ef:RuleOfFundamentality rdf:type ef:Concept, skos:Concept ;
    rdfs:label "Rule of Fundamentality" ;
    skos:prefLabel "Rule of Fundamentality" ;
    skos:definition "A candidate concept distinction is justified when its defining characteristic explains the greatest number of other characteristics of the units it groups." ;
    skos:broader ef:RandianConceptFormation ;
    ef:adoptedDefinition "The rule that the essential characteristic of a concept is the deepest available explanatory root of the units in scope." ;
    ef:variants "essential characteristic", "fundamental characteristic" ;
    ef:kind ef:NodeKindConcept ;
    ef:lifecycleStatus ef:StatusAdopted ;
    ef:dependsOn ef:RandianConceptFormation .

ef:MeasurementOmission rdf:type ef:Concept, skos:Concept ;
    rdfs:label "measurement-omission" ;
    skos:prefLabel "measurement-omission" ;
    skos:definition "Concepts may abstract over differences in degree or measurement while retaining that the defining characteristic exists in some measure." ;
    skos:broader ef:RandianConceptFormation ;
    ef:adoptedDefinition "A concept-formation move that omits specific measurements while retaining the existence of the shared characteristic being abstracted." ;
    ef:variants "concept-formation via measurement-omission", "measurement omission" ;
    ef:kind ef:NodeKindConcept ;
    ef:lifecycleStatus ef:StatusAdopted ;
    ef:dependsOn ef:RandianConceptFormation .

ef:ContextualEssentiality rdf:type ef:Concept, skos:Concept ;
    rdfs:label "contextual essentiality" ;
    skos:prefLabel "contextual essentiality" ;
    skos:definition "The essential characteristic of a concept is selected relative to the current state of knowledge; better knowledge may justify a better distinction later." ;
    skos:broader ef:RuleOfFundamentality ;
    ef:adoptedDefinition "The rule that essential characteristics are objective within context: choose the deepest distinction currently supported by what is actually known." ;
    ef:variants "contextual essentials", "contextual essence" ;
    ef:kind ef:NodeKindConcept ;
    ef:lifecycleStatus ef:StatusAdopted ;
    ef:dependsOn ef:RandianConceptFormation, ef:RuleOfFundamentality .

ef:ExplanatoryPower rdf:type ef:Concept, skos:Concept ;
    rdfs:label "explanatory power" ;
    skos:prefLabel "explanatory power" ;
    skos:definition "The strength of a concept's defining characteristic is judged by how much of the grouped units' downstream behavior, lifecycle, and relationships it explains." ;
    skos:broader ef:RuleOfFundamentality ;
    ef:adoptedDefinition "The test that a proposed distinction is worth modeling when it explains a wide cascade of other characteristics rather than merely naming a visible surface similarity." ;
    ef:variants "explanatory root", "explanatory depth" ;
    ef:kind ef:NodeKindConcept ;
    ef:lifecycleStatus ef:StatusAdopted ;
    ef:dependsOn ef:RuleOfFundamentality .

ef:EssentialCharacteristicNodeSelection rdf:type ef:Guidance, skos:Concept ;
    rdfs:label "essential-characteristic node selection" ;
    skos:prefLabel "essential-characteristic node selection" ;
    skos:definition "A guidance rule for ontology editing: admit a node only when its defining characteristic explains the greatest number of other characteristics of the units it groups; otherwise keep it out of the ontology or treat it as guidance rather than a canonical term." ;
    ef:adoptedDefinition "A guidance rule for ontology editing: admit a node only when its defining characteristic explains the greatest number of other characteristics of the units it groups; otherwise keep it out of the ontology or treat it as guidance rather than a canonical term." ;
    ef:kind ef:NodeKindGuidance ;
    ef:lifecycleStatus ef:StatusAdopted ;
    ef:governedBy ef:RandianConceptFormation ;
    ef:dependsOn ef:MeasurementOmission, ef:ExplanatoryPower .

### Knowledge-Tree Individuals — Stabilization & Kernels (EF-053 / EF-054)

ef:BootstrapRule rdf:type ef:Tenet, skos:Concept ;
    rdfs:label "bootstrap rule" ;
    skos:prefLabel "bootstrap rule" ;
    skos:definition "The doctrine that prevents the self-improvement grind: a factory may trust a layer's autonomy only once the layers beneath it are kernels. Gall's Law operationalized — a complex system that works is invariably found to have evolved from a simple system that worked, so autonomy is grown upward from a trustworthy foundation, never built from scratch over un-kernelled substrate. Governs Loop A (trusting autonomy), not Loop B (adding detection), which is always-valid work on any layer regardless of the bootstrap order." ;
    ef:statement "A layer's autonomy may be trusted only once the layers beneath it are kernels." ;
    ef:variants "bootstrap order", "trust autonomy upward only", "Gall's Law" ;
    ef:kind ef:NodeKindTenet ;
    ef:lifecycleStatus ef:StatusAdopted .

ef:DetectionRatchet rdf:type ef:Concept, skos:Concept ;
    rdfs:label "detection ratchet" ;
    skos:prefLabel "detection ratchet" ;
    skos:definition "The detectable half of a kernel: a single-command, unambiguous pass/fail check (smoke test or hard gate) that proves an element is still good. Detection is the negentropy input — Lehman's Laws hold that complexity rises in any layer still in use unless deliberate work reduces it, and the ratchet is that deliberate work: it converts silent drift into a caught, bounded red-gate event. Detection — not stability — is the half almost always missing, and the half that does the work. Operationalized by the paired-detection standard (04-standards/09)." ;
    ef:adoptedDefinition "A cheap, re-runnable, one-command pass/fail check that proves an element is still good, supplying the continuous detection that keeps a kernel a kernel." ;
    ef:variants "smoke gate", "smoke test", "hard gate", "one-command gate", "negentropy input", "paired detection", "Lehman's Laws", "Lehman" ;
    ef:kind ef:NodeKindConcept ;
    ef:lifecycleStatus ef:StatusAdopted .

ef:Kernel rdf:type ef:Concept, skos:Concept ;
    rdfs:label "kernel" ;
    skos:prefLabel "kernel" ;
    skos:altLabel "candidate kernel", "stable foundation", "trustworthy foundation", "what can I build on", "what is solid enough to build on" ;
    skos:definition "A substrate or control-layer element that is both stable and detectable — confirmable good in a single command — and is therefore trustworthy to build on." ;
    rdfs:comment "The primitive that prevents the self-improvement grind (using a not-yet-working tool to fix a not-yet-working tool). A kernel needs two properties, not one: stable (pinned/frozen/source-controlled — it does not change under you) AND detectable (confirmable good in one command). Stability without detection is only 'code you haven't broken yet.' Yields three states — kernel (stable+detectable), candidate kernel (stable, detection partial/just added), not-a-kernel (fast-moving) — where the candidate->kernel promotion is exactly the event 'detection was added.' Kernel state is the maturity model applied to substrate, not a new lifecycle vocabulary. External-tier dependencies (frontier-model / vendor APIs) are inherently un-kernelable — they change on the vendor's schedule and cannot be pinned, so they must be wrapped by an Adapter that carries its own detection and never trusted as foundation." ;
    ef:adoptedDefinition "A substrate or control-layer element that is both stable and detectable — confirmable good in a single command — and is therefore trustworthy to build on." ;
    ef:variants "candidate kernel", "stable foundation", "trustworthy foundation", "what can I build on", "what is solid enough to build on" ;
    ef:kind ef:NodeKindConcept ;
    ef:lifecycleStatus ef:StatusAdopted ;
    ef:governedBy ef:BootstrapRule ;
    ef:dependsOn ef:DetectionRatchet .

ef:FoundationTrust rdf:type ef:Concept, skos:Concept ;
    rdfs:label "foundation-trust" ;
    skos:prefLabel "foundation-trust" ;
    skos:definition "One of the two orthogonal axes a factory uses to grade 'how solid is this?'. Foundation-trust answers 'what may I build on?' and is governed by kernel state plus the bootstrap order; it applies to the substrate and control layers. It is independent of, and MUST NOT be conflated with, the product-promotion axis: whether the substrate an artifact runs on is a kernel is a different question from whether that artifact is safe to ship. Trust in a foundation comes from kernels, not from ring promotion." ;
    ef:adoptedDefinition "The axis that grades what may be built upon — governed by kernel state and the bootstrap order — held distinct from whether a product is safe to ship." ;
    ef:variants "foundation-trust axis", "what may I build on" ;
    ef:kind ef:NodeKindConcept ;
    ef:lifecycleStatus ef:StatusAdopted ;
    ef:dependsOn ef:Kernel, ef:BootstrapRule .

ef:ProductPromotion rdf:type ef:Concept, skos:Concept ;
    rdfs:label "product-promotion" ;
    skos:prefLabel "product-promotion" ;
    skos:definition "One of the two orthogonal axes a factory uses to grade 'how solid is this?'. Product-promotion answers 'is this artifact safe to ship?' and is governed by the maturity model plus release rings; it applies to the products the factory builds. It is independent of, and MUST NOT be conflated with, the foundation-trust axis: a product moving alpha->beta->GA is a separate question from whether the substrate beneath it is a kernel. Quality of a shipped product comes from rings and feedback-minted checks, not from being frozen." ;
    ef:adoptedDefinition "The axis that grades whether a product is safe to ship — governed by the maturity model and release rings — held distinct from what may be built upon." ;
    ef:variants "product-promotion axis", "is this safe to ship" ;
    ef:kind ef:NodeKindConcept ;
    ef:lifecycleStatus ef:StatusAdopted ;
    ef:dependsOn ef:ReleaseRingsComponent .

