{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Launch Gemini (sandbox)",
      "type": "shell",
      "command": "runas",
      "args": [
        "/user:gemini-runner",
        "/savecred",
        "${workspaceFolder}\\scripts\\run-gemini-sandbox-as-runner.cmd"
      ],
      "problemMatcher": []
    },
    {
      "label": "Launch eposforge MCP (http)",
      "type": "shell",
      "command": "pwsh",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\scripts\\run-eposforge-mcp-http.ps1"
      ],
      "isBackground": true,
      "problemMatcher": []
    }
  ]
}
