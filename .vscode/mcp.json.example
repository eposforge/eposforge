{
  "servers": {
    "eposforge-graph": {
      "type": "stdio",
      "command": "<abs-path-to>\\graphrag\\.venv\\Scripts\\mcp-neo4j-cypher.exe",
      "args": ["--read-only"],
      "env": {
        "NEO4J_URI": "bolt://localhost:7688",
        "NEO4J_USERNAME": "neo4j",
        "NEO4J_PASSWORD": "<your-neo4j-password>"
      }
    },
    "github": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "<your-github-pat>"
      }
    },
    "ms-docs": {
      "type": "http",
      "url": "https://learn.microsoft.com/api/mcp"
    },
    "cognee": {
      "type": "stdio",
      "command": "uvx",
      "args": ["cognee-mcp"],
      "env": {
        "LLM_PROVIDER": "azure",
        "LLM_MODEL": "azure/<your-azure-deployment-name>",
        "LLM_ENDPOINT": "https://<your-resource>.openai.azure.com/openai/deployments/<your-azure-deployment-name>",
        "LLM_API_KEY": "<your-azure-openai-api-key>",
        "LLM_API_VERSION": "2024-12-01-preview"
      }
    }
  }
}
