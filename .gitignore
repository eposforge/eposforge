# Local secrets — never commit
.env
.env.*

# AI assistant machine-specific configs
.mcp.json
.vscode/mcp.json
.claude/settings.local.json

# Age private key — never commit
**/keys.txt

# Audit log — local only
instance/.audit/

# Plaintext secrets staging file — deleted after encryption but gitignore as safety net
**/secrets.plaintext.yaml

# Node / Gemini CLI
node_modules/
.gemini/*
!.gemini/settings.json.example
package-lock.json

# GraphRAG runtime output
graphrag/output/
graphrag/cache/
graphrag/.venv/
graphrag/__pycache__/
graphrag/*.pyc
