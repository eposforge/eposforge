# Local secrets — never commit
.env
.env.*

# AI assistant machine-specific configs
.mcp.json
.vscode/mcp.json
.claude/settings.local.json

# Age private key — never commit
**/keys.txt

# Audit log — local only
instance/.audit/

# Plaintext secrets staging file — deleted after encryption but gitignore as safety net
**/secrets.plaintext.yaml

# Real encrypted vault — adopters keep their own; the framework ships secrets.example.yaml only
**/secrets.enc.yaml

# Node / Gemini CLI
node_modules/
.gemini/*
!.gemini/settings.json.example
package-lock.json

# GraphRAG runtime output
graphrag/output/
graphrag/cache/
graphrag/.venv/
graphrag/__pycache__/
graphrag/*.pyc
instance/installed/06-spec-graph/graphrag/output/
instance/installed/06-spec-graph/graphrag/cache/
instance/installed/06-spec-graph/graphrag/.venv/
instance/installed/06-spec-graph/graphrag/__pycache__/
instance/installed/06-spec-graph/cognee/.venv/
instance/installed/06-spec-graph/cognee/__pycache__/
instance/installed/06-spec-graph/cognee/.cognee/

# Scratchpad — never commit (temp files, plans, scratch notes, diffs, logs)
.scratchpad/
scratchpad/

# Python runtime cache artifacts
**/__pycache__/
**/*.pyc

# Generated machine authorization request artifact
epos-machine-request.json

# Generated portfolio diagrams (Mermaid cross-repo views from aggregate.sh --mermaid).
# These MUST NOT contain private adopter data (GEA, IAC, Outreach*, etc.).
# Enforcement:
# - aggregate.sh --mermaid now selects the first `visibility=private` root as write target
#   whenever any private root participates (prevents writing mixed/private diagrams into
#   the public framework tree even if BACKLOG_ROOTS lists the public root first).
# - Run framework-only when you want a public-safe diagram in the gh/eposforge tree.
# - The public root .gitignore (portfolio.md + **/portfolio.md) is the final defense.
portfolio.md
**/portfolio.md

# Gas Town (added by gt)
.runtime/
.claude/
.opencode/
.logs/
__pycache__/
state.json
CLAUDE.md
CLAUDE.local.md
GEMINI.md
