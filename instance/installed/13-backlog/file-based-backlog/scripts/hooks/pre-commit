#!/usr/bin/env bash
# pre-commit fragment owned by 13-backlog.
# Runs backlog lint checks for staged active/slated backlog changes.
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
LINT_SCRIPT="${REPO_ROOT}/instance/installed/13-backlog/file-based-backlog/scripts/lint-backlog.sh"

if [[ ! -x "${LINT_SCRIPT}" ]]; then
  echo "ERROR: backlog lint script is missing or not executable: ${LINT_SCRIPT}" >&2
  exit 1
fi

changed="$(git diff --cached --name-only)"
if ! grep -Eq '^instance/backlog/(backlog\.md|backlog-slated\.md)$' <<<"${changed}"; then
  exit 0
fi

"${LINT_SCRIPT}" --staged