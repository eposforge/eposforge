efi:env-vars rdf:type ef:ReferenceImplementation ;
    rdfs:label "env-vars" ;
    ef:adapterName "env-vars" ;
    ef:adapterVersion "0.1.0" ;
    ef:privacyPosture "local" ;
    ef:costHint "free" ;
    ef:invocationSurface "process environment" ;
    ef:capabilities "runtime-config-injection", "bootstrap-passthrough" ;
    ef:fulfillsSlot ef:SecretsKeyManagementComponent ;
    ef:hasStatus ef:AdapterStatusExperimental .

efi:sops-age rdf:type ef:ReferenceImplementation ;
    rdfs:label "sops-age" ;
    ef:adapterName "sops-age" ;
    ef:adapterVersion "0.1.0" ;
    ef:privacyPosture "local" ;
    ef:costHint "free" ;
    ef:invocationSurface "sops CLI + age keying; runtime injection via epos-secrets resolver" ;
    ef:capabilities "encrypted-file-store", "multi-machine-sharing", "two-state-rotation", "cross-platform" ;
    ef:fulfillsSlot ef:SecretsKeyManagementComponent ;
    ef:hasStatus ef:AdapterStatusExperimental .

efi:windows-credential-manager rdf:type ef:ReferenceImplementation ;
    rdfs:label "windows-credential-manager" ;
    ef:adapterName "windows-credential-manager" ;
    ef:adapterVersion "0.1.0" ;
    ef:privacyPosture "local" ;
    ef:costHint "free" ;
    ef:invocationSurface "Windows Credential Manager via cmdkey / PowerShell" ;
    ef:capabilities "per-user-credential-isolation", "least-privilege-scoping" ;
    ef:fulfillsSlot ef:SecretsKeyManagementComponent ;
    ef:hasStatus ef:AdapterStatusExperimental .

efi:file-based-backlog rdf:type ef:ReferenceImplementation ;
    rdfs:label "file-based-backlog" ;
    ef:adapterName "file-based-backlog" ;
    ef:adapterVersion "0.1.0" ;
    ef:privacyPosture "local" ;
    ef:costHint "free" ;
