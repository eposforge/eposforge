#!/usr/bin/env python3
"""epos-secrets — Component 12 resolver shim for EposForge.

Walks all secrets.toml manifests under instance/installed/12-secrets-key-management/,
decrypts SOPS-encrypted secrets, and exec's a child process with the resolved
environment variables populated.

Usage:
    epos-secrets -- <child-command> [args...]
    epos-secrets --only VAR1,VAR2 -- <child-command> [args...]
    epos-secrets --check
    epos-secrets --list

Invocation on Windows (Python is required):
    python instance/installed/12-secrets-key-management/bin/epos-secrets -- pwsh ./script.ps1

Environment variables honored by the resolver itself:
    EPOS_ENV         Current environment name (default: dev).
    EPOS_USE_NEXT    If set to "1", prefer <logical_name>_next values from
                     secrets.enc.yaml over the primary value (rotation window).
    EPOS_AUDIT_SINK  Path to append secret.accessed JSON events. Defaults to
                     instance/.audit/secret-access.jsonl relative to repo root.
"""

import datetime
import json
import os
import pathlib
import subprocess
import sys

if sys.version_info < (3, 11):
    print("ERROR: epos-secrets requires Python 3.11 or newer.", file=sys.stderr)
    sys.exit(1)

import tomllib  # stdlib since 3.11

# ---------------------------------------------------------------------------
# Locate repo root (four levels up from this script:
#   bin/ -> 12-secrets-key-management/ -> installed/ -> instance/ -> repo/)
# ---------------------------------------------------------------------------
_SCRIPT_DIR = pathlib.Path(__file__).resolve().parent
_SECRETS_ROOT = _SCRIPT_DIR.parent  # 12-secrets-key-management/
_REPO_ROOT = _SECRETS_ROOT.parent.parent.parent  # repo root


def _audit_sink() -> pathlib.Path:
    sink_env = os.environ.get("EPOS_AUDIT_SINK")
    if sink_env:
        return pathlib.Path(sink_env)
    return _REPO_ROOT / "instance" / ".audit" / "secret-access.jsonl"


def _emit_audit(logical_name: str, runtime_name: str, adapter: str, argv0: str) -> None:
    sink = _audit_sink()
    sink.parent.mkdir(parents=True, exist_ok=True)
    record = {
        "ts": datetime.datetime.now(datetime.timezone.utc).isoformat(),
        "logical_name": logical_name,
        "runtime_name": runtime_name,
        "consumer_argv0": argv0,
        "pid": os.getpid(),
        "adapter": adapter,
    }
    with sink.open("a", encoding="utf-8") as fh:
        fh.write(json.dumps(record) + "\n")


# ---------------------------------------------------------------------------
# Manifest loading
# ---------------------------------------------------------------------------

def _load_manifests() -> list[dict]:
    """Return a list of (manifest_dict, toml_path) tuples for all adapters."""
    results = []
    for toml_path in sorted(_SECRETS_ROOT.glob("*/secrets.toml")):
        with toml_path.open("rb") as fh:
            data = tomllib.load(fh)
        results.append((data, toml_path))
    return results


def _build_secret_index(manifests: list[tuple[dict, pathlib.Path]]) -> dict[str, dict]:
    """
    Build a flat index: logical_name -> secret entry dict (with _adapter and _toml_path injected).
    Fails loudly on runtime_name collisions between adapters that both inject into env.
    windows-credential-manager entries are validation-only and do not inject, so they
    are exempt from runtime_name collision checks.
    """
    by_logical: dict[str, dict] = {}
    # Only track runtime_name -> logical for injecting adapters (not windows-credential-manager)
    runtime_to_logical: dict[str, str] = {}

    for manifest_data, toml_path in manifests:
        adapter = manifest_data.get("manifest", {}).get("adapter", toml_path.parent.name)
        is_injecting = adapter != "windows-credential-manager"

        for secret in manifest_data.get("secret", []):
            logical = secret["logical_name"]
            runtime = secret["runtime_name"]

            if logical in by_logical:
                existing = by_logical[logical]
                print(
                    f"ERROR: logical_name collision: '{logical}' declared in both "
                    f"'{existing['_adapter']}' and '{adapter}'. Fix secrets.toml.",
                    file=sys.stderr,
                )
                sys.exit(1)

            if is_injecting and runtime in runtime_to_logical:
                other = runtime_to_logical[runtime]
                print(
                    f"ERROR: runtime_name collision: '{runtime}' declared by both "
                    f"'{other}' and '{logical}' (injecting adapters). Each runtime env var "
                    f"must have exactly one injecting owner. Fix secrets.toml.",
                    file=sys.stderr,
                )
                sys.exit(1)

            enriched = dict(secret)
            enriched["_adapter"] = adapter
            enriched["_toml_path"] = str(toml_path)
            by_logical[logical] = enriched
            if is_injecting:
                runtime_to_logical[runtime] = logical

    return by_logical


# ---------------------------------------------------------------------------
# SOPS decryption
# ---------------------------------------------------------------------------

_SOPS_CACHE: dict[pathlib.Path, dict] = {}


def _parse_simple_yaml_mapping(text: str, source: pathlib.Path) -> dict[str, str]:
    data: dict[str, str] = {}

    for line_number, raw_line in enumerate(text.splitlines(), start=1):
        line = raw_line.strip()
        if not line or line.startswith("#"):
            continue
        if ":" not in line:
            print(
                f"ERROR: unsupported decrypted YAML in {source} at line {line_number}: {raw_line}",
                file=sys.stderr,
            )
            sys.exit(1)

        key, value = line.split(":", 1)
        key = key.strip()
        value = value.strip()
        if not key:
            print(
                f"ERROR: invalid empty key in decrypted YAML for {source} at line {line_number}.",
                file=sys.stderr,
            )
            sys.exit(1)

        if value.startswith(('"', "'")) and value.endswith(('"', "'")) and len(value) >= 2:
            value = value[1:-1]

        data[key] = value

    return data


def _decrypt_sops(enc_file: pathlib.Path) -> dict:
    if enc_file in _SOPS_CACHE:
        return _SOPS_CACHE[enc_file]

    if not enc_file.exists():
        print(
            f"ERROR: sops-age encrypted file not found: {enc_file}\n"
            f"  Initialize it by running:\n"
            f"    sops {enc_file}\n"
            f"  See {enc_file.parent}/sops-age.md for bootstrap instructions.",
            file=sys.stderr,
        )
        sys.exit(1)

    try:
        result = subprocess.run(
            ["sops", "--decrypt", "--output-type", "json", str(enc_file)],
            capture_output=True,
            text=True,
            check=True,
        )
    except FileNotFoundError:
        print(
            "ERROR: 'sops' not found on PATH.\n"
            "  Install: sudo apt install sops  OR  winget install Mozilla.SOPS",
            file=sys.stderr,
        )
        sys.exit(1)
    except subprocess.CalledProcessError as exc:
        if "Error marshaling to json" not in exc.stderr:
            print(
                f"ERROR: sops decryption failed for {enc_file}:\n{exc.stderr}",
                file=sys.stderr,
            )
            sys.exit(1)

        try:
            fallback = subprocess.run(
                ["sops", "--decrypt", str(enc_file)],
                capture_output=True,
                text=True,
                check=True,
            )
        except subprocess.CalledProcessError as fallback_exc:
            print(
                f"ERROR: sops decryption failed for {enc_file}:\n{fallback_exc.stderr}",
                file=sys.stderr,
            )
            sys.exit(1)

        plaintext = _parse_simple_yaml_mapping(fallback.stdout, enc_file)
    else:
        plaintext = json.loads(result.stdout)

    _SOPS_CACHE[enc_file] = plaintext
    return plaintext


# ---------------------------------------------------------------------------
# Resolution per adapter
# ---------------------------------------------------------------------------

def _resolve_secret(
    secret: dict,
    epos_env: str,
    use_next: bool,
) -> tuple[str | None, bool]:
    """
    Returns (value, skipped).
    skipped=True means the entry was intentionally not resolved (e.g. wrong env,
    or windows-credential-manager entries that don't inject into operator env).
    value=None means missing.
    """
    adapter = secret["_adapter"]
    required_envs = secret.get("required_environments", [])

    # Skip entries that don't apply to the current environment
    if required_envs and epos_env not in required_envs:
        return (None, True)

    if adapter == "env-vars":
        value = os.environ.get(secret["runtime_name"])
        return (value, False)

    elif adapter == "sops-age":
        sops_dir = _SECRETS_ROOT / "sops-age"
        manifest_data = _load_sops_manifest_meta(sops_dir)
        enc_file = sops_dir / manifest_data.get("encrypted_file", "secrets.enc.yaml")
        plaintext = _decrypt_sops(enc_file)

        logical = secret["logical_name"]
        key = f"{logical}_next" if use_next and f"{logical}_next" in plaintext else logical
        value = plaintext.get(key)
        return (value, False)

    elif adapter == "windows-credential-manager":
        # This adapter does not inject into the operator's env.
        # It validates presence when running as gemini-runner.
        return (None, True)

    else:
        print(f"WARNING: unknown adapter '{adapter}' for '{secret['logical_name']}'; skipping.", file=sys.stderr)
        return (None, True)


_SOPS_MANIFEST_META_CACHE: dict[pathlib.Path, dict] = {}


def _load_sops_manifest_meta(sops_dir: pathlib.Path) -> dict:
    if sops_dir in _SOPS_MANIFEST_META_CACHE:
        return _SOPS_MANIFEST_META_CACHE[sops_dir]
    toml_path = sops_dir / "secrets.toml"
    with toml_path.open("rb") as fh:
        data = tomllib.load(fh)
    meta = data.get("manifest", {})
    _SOPS_MANIFEST_META_CACHE[sops_dir] = meta
    return meta


# ---------------------------------------------------------------------------
# --check mode
# ---------------------------------------------------------------------------

def cmd_check() -> int:
    epos_env = os.environ.get("EPOS_ENV", "dev")
    use_next = os.environ.get("EPOS_USE_NEXT", "0") == "1"

    manifests = _load_manifests()
    if not manifests:
        print("ERROR: No secrets.toml files found under", _SECRETS_ROOT, file=sys.stderr)
        return 1

    secret_index = _build_secret_index(manifests)

    print(f"epos-secrets --check  (EPOS_ENV={epos_env}, EPOS_USE_NEXT={use_next})")
    print(f"Manifest root: {_SECRETS_ROOT}")
    print(f"Secrets declared: {len(secret_index)}")
    print()

    errors = 0
    for logical, secret in sorted(secret_index.items()):
        adapter = secret["_adapter"]
        runtime = secret["runtime_name"]
        required_envs = secret.get("required_environments", [])
        env_note = f"[envs: {','.join(required_envs) or 'any'}]"

        if adapter == "windows-credential-manager":
            current_user = os.environ.get("USERNAME", os.environ.get("USER", ""))
            if current_user == "gemini-runner":
                # Validate via PowerShell Get-StoredCredential
                target = secret.get("source_of_truth", "")
                status = _check_windows_credential(target)
            else:
                status = f"[SKIP] not gemini-runner (current user: {current_user})"
            print(f"  {adapter:30s}  {logical:40s}  {runtime:45s}  {status}  {env_note}")
            continue

        value, skipped = _resolve_secret(secret, epos_env, use_next)

        if skipped:
            status = f"[SKIP] env '{epos_env}' not in required_environments"
        elif value is None:
            if required_envs and epos_env in required_envs:
                status = "[MISSING]"
                errors += 1
            else:
                status = "[MISSING] (not required in this env)"
        else:
            redacted = _redact(value)
            status = f"[OK] {redacted}"

        print(f"  {adapter:30s}  {logical:40s}  {runtime:45s}  {status}  {env_note}")

    print()
    if errors:
        print(f"RESULT: {errors} error(s). Run 'epos-secrets --check' after fixing.", file=sys.stderr)
        return 1
    else:
        print("RESULT: OK — all required secrets present.")
        return 0


def _check_windows_credential(source_of_truth: str) -> str:
    """Check Windows Credential Manager for a target; return status string."""
    # Extract target name from source_of_truth string
    # Format: "Windows Credential Manager target: <target-name>"
    prefix = "Windows Credential Manager target:"
    if prefix in source_of_truth:
        target = source_of_truth.split(prefix, 1)[1].strip()
    else:
        return "[SKIP] could not parse target from source_of_truth"

    try:
        result = subprocess.run(
            [
                "powershell", "-NoProfile", "-Command",
                f"$c = Get-StoredCredential -Target '{target}' -ErrorAction SilentlyContinue; "
                f"if ($c) {{ Write-Output 'FOUND' }} else {{ Write-Output 'MISSING' }}"
            ],
            capture_output=True, text=True, timeout=10,
        )
        output = result.stdout.strip()
        if output == "FOUND":
            return "[OK] present in Credential Manager"
        else:
            return "[MISSING] not found in Credential Manager"
    except Exception as exc:
        return f"[ERROR] {exc}"


def _redact(value: str) -> str:
    """Return a redacted hint of a secret value."""
    if not value:
        return "(empty)"
    prefixes = ["sk-ant-", "sk-proj-", "ghp_", "github_pat_", "AIza"]
    for prefix in prefixes:
        if value.startswith(prefix):
            return f"{prefix}***"
    return f"{value[:4]}***"


# ---------------------------------------------------------------------------
# --list mode
# ---------------------------------------------------------------------------

def cmd_list() -> int:
    manifests = _load_manifests()
    secret_index = _build_secret_index(manifests)
    print(f"{'ADAPTER':30s}  {'LOGICAL_NAME':40s}  {'RUNTIME_NAME':45s}  {'REQUIRED_ENVS'}")
    for logical, secret in sorted(secret_index.items()):
        envs = ",".join(secret.get("required_environments", [])) or "any"
        print(f"  {secret['_adapter']:30s}  {logical:40s}  {secret['runtime_name']:45s}  {envs}")
    return 0


# ---------------------------------------------------------------------------
# Main exec flow
# ---------------------------------------------------------------------------

def cmd_exec(child_argv: list[str], only: list[str] | None) -> None:
    """Resolve secrets into env and exec the child."""
    epos_env = os.environ.get("EPOS_ENV", "dev")
    use_next = os.environ.get("EPOS_USE_NEXT", "0") == "1"

    manifests = _load_manifests()
    secret_index = _build_secret_index(manifests)

    child_env = dict(os.environ)
    argv0 = pathlib.Path(child_argv[0]).name if child_argv else "unknown"

    for logical, secret in secret_index.items():
        runtime = secret["runtime_name"]

        # --only filter
        if only is not None and runtime not in only:
            continue

        value, skipped = _resolve_secret(secret, epos_env, use_next)

        if skipped:
            continue

        if value is None:
            required_envs = secret.get("required_environments", [])
            if required_envs and epos_env in required_envs:
                print(
                    f"ERROR: Required secret '{logical}' (runtime: {runtime}) is missing "
                    f"for env '{epos_env}'. Run 'epos-secrets --check' for details.",
                    file=sys.stderr,
                )
                sys.exit(1)
            continue

        child_env[runtime] = value
        _emit_audit(logical, runtime, secret["_adapter"], argv0)

    # exec the child
    if sys.platform == "win32":
        # Windows: subprocess.run (no true execvp)
        result = subprocess.run(child_argv, env=child_env)
        sys.exit(result.returncode)
    else:
        os.execvpe(child_argv[0], child_argv, child_env)


# ---------------------------------------------------------------------------
# Argument parsing (stdlib only — no argparse dependency on intent)
# ---------------------------------------------------------------------------

def _parse_args(argv: list[str]) -> dict:
    args = argv[1:]  # skip script name

    if not args:
        print(__doc__)
        sys.exit(0)

    if args[0] == "--check":
        return {"mode": "check"}

    if args[0] == "--list":
        return {"mode": "list"}

    only: list[str] | None = None
    while args and args[0].startswith("--"):
        flag = args.pop(0)
        if flag == "--only":
            if not args:
                print("ERROR: --only requires a comma-separated list of runtime var names.", file=sys.stderr)
                sys.exit(1)
            only = [v.strip() for v in args.pop(0).split(",")]
        elif flag == "--":
            break
        else:
            print(f"ERROR: unknown flag '{flag}'.", file=sys.stderr)
            sys.exit(1)

    # consume trailing '--' separator if present
    if args and args[0] == "--":
        args.pop(0)

    if not args:
        print("ERROR: no child command provided after '--'.", file=sys.stderr)
        sys.exit(1)

    return {"mode": "exec", "child": args, "only": only}


def main() -> None:
    parsed = _parse_args(sys.argv)

    if parsed["mode"] == "check":
        sys.exit(cmd_check())
    elif parsed["mode"] == "list":
        sys.exit(cmd_list())
    elif parsed["mode"] == "exec":
        cmd_exec(parsed["child"], parsed.get("only"))


if __name__ == "__main__":
    main()
