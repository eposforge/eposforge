#!/usr/bin/env python3
"""Generate a machine authorization request for sops-age recipients.

Usage:
  epos-machine-request

This script generates an age key pair, displays the private key with
instructions to save it to your secrets vault, and waits for confirmation.

Share the displayed fingerprint with your approver, who will then run:
  epos-authorize <machine> <fingerprint> <pubkey>
"""

import pathlib
import subprocess
import sys


def main() -> int:
    repo_root = pathlib.Path(__file__).resolve().parents[4]
    core = repo_root / "instance" / "installed" / "12-secrets-key-management" / "sops-age" / "scripts" / "setup_core.py"
    cmd = [sys.executable, str(core), "request", *sys.argv[1:]]
    return subprocess.call(cmd)


if __name__ == "__main__":
    raise SystemExit(main())
