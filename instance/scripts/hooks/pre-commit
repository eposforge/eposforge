#!/usr/bin/env bash
# pre-commit — Block committing private network endpoints and machine-local paths.
#
# Install via:
#   bash instance/scripts/hooks/install-hooks.sh
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
CHECK_SCRIPT="${REPO_ROOT}/instance/installed/09-source-control-ci/github-and-actions/scripts/check-sensitive-literals.sh"

if [[ ! -x "${CHECK_SCRIPT}" ]]; then
  echo "ERROR: checker script is missing or not executable: ${CHECK_SCRIPT}" >&2
  exit 1
fi

"${CHECK_SCRIPT}" --staged
